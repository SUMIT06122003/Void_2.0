PORT=4000
API_PROXY_TARGET=http://127.0.0.1:4000
# Frontend build uses this to call the deployed backend.
# Vercel example: API_BASE_URL=https://your-backend.onrender.com
# Phone testing example: API_BASE_URL=http://192.168.1.10:4000
API_BASE_URL=
# Backend CORS uses these to allow the hosted frontend.
# Example: FRONTEND_ORIGIN=https://your-store.vercel.app
FRONTEND_ORIGIN=
ALLOWED_ORIGINS=
META_PIXEL_ID=
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
# Comma-separated admin phones. Leave blank to disable admin access.
ADMIN_MOBILE_NUMBERS=

# MongoDB persistence for users, addresses, and orders.
# Local: mongodb://127.0.0.1:27017
# Atlas: mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net
MONGODB_URI=
MONGODB_DB=void_store

# Use "console" while building. Switch to "messagecentral" only after configuring real credentials.
OTP_PROVIDER=console
DEV_OTP=123456
OTP_TTL_MS=300000

MESSAGE_CENTRAL_BASE_URL=https://cpaas.messagecentral.com
MESSAGE_CENTRAL_SEND_OTP_PATH=/verification/v3/send
MESSAGE_CENTRAL_VERIFY_OTP_PATH=/verification/v3/validateOtp
MESSAGE_CENTRAL_CUSTOMER_ID=
MESSAGE_CENTRAL_AUTH_TOKEN=
MESSAGE_CENTRAL_COUNTRY_CODE=91
MESSAGE_CENTRAL_FLOW_TYPE=SMS

# Cloudinary delivery. Only the cloud name is needed for public media delivery.
# Leave empty to keep using bundled local assets.
CLOUDINARY_CLOUD_NAME=
